@startuml class_watchlist

' ============================================================
'  CINEMATE — Diagramme de Classes : Gestion de la Watchlist
' ============================================================

skinparam shadowing false
skinparam RoundCorner 5
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #333333
    FontSize 12
}
skinparam note {
    BackgroundColor #FFFFCC
    BorderColor #CCCCAA
}

' Espacement augmenté pour rendre les textes et cardinalités bien visibles
skinparam nodesep 80
skinparam ranksep 70
skinparam ArrowFontSize 13

title Diagramme de Classes — Ajout d'un Film à la Watchlist

' ─────────────────────────────────────
'   FRONTEND
' ─────────────────────────────────────

class Watchlist <<page>> {
    - toWatch : Movie[]
    - watched : Movie[]
    __
    Route : /watchlist
}

class MovieDetails <<page>> {
    - movie : Movie
    __
    Route : /movie/:id
}

class AuthContext <<provider>> {
    - user : User
    - isAuthenticated : boolean
    __
    + updateUser(data : Partial<User>) : void
}

class MovieContext <<provider>> {
    - movies : Movie[]
    __
    + getMovie(id : string) : Movie
}

class ApiService <<service>> {
    - baseURL : string
    __
    + put(url : string, data : object) : Promise
}

' ─────────────────────────────────────
'   BACKEND
' ─────────────────────────────────────

class ProfileController <<controller>> {
    __
    + update(request : Request, em : EntityManagerInterface) : JsonResponse
}

class User <<entity>> {
    - id : int
    - username : string
    __
    + getWatchlists() : Collection
    + addWatchlistRelation(w : UserWatchlist) : static
    + removeWatchlistRelation(w : UserWatchlist) : static
}

class Movie <<entity>> {
    - id : int
    - title : string
    - runtime : int
    __
    + getId() : ?int
    + getTitle() : ?string
}

class UserWatchlist <<entity>> {
    - statut : string
    __
    + getUser() : ?User
    + setUser(user : User) : static
    + getMovie() : ?Movie
    + setMovie(movie : Movie) : static
    + getStatut() : ?string
    + setStatut(statut : string) : static
}

note bottom of UserWatchlist
    Clé primaire composite
    (Id_Utilisateur, Id_Film)
    statut : "a_voir" | "vu"
end note

' ─────────────────────────────────────
'   RELATIONS FRONTEND
' ─────────────────────────────────────

Watchlist ..> AuthContext : <<use>>
Watchlist ..> MovieContext : <<use>>
MovieDetails ..> AuthContext : <<use>>
MovieDetails ..> MovieContext : <<use>>
AuthContext ..> ApiService : <<use>>

' ─────────────────────────────────────
'   FLUX API
' ─────────────────────────────────────

ApiService ..> ProfileController : PUT /api/profile

' ─────────────────────────────────────
'   RELATIONS BACKEND (Doctrine ORM)
' ─────────────────────────────────────

ProfileController ..> UserWatchlist : <<create>>
ProfileController ..> User : <<use>>

User "1" *-down- "0..*" UserWatchlist
UserWatchlist "0..*" -right-o "1" Movie

@enduml
