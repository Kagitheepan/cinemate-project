@startuml class_movie

' ============================================================
'  CINEMATE — Diagramme de Classes : Consultation d'un Film
' ============================================================

skinparam shadowing false
skinparam RoundCorner 5
skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #333333
    FontSize 12
}
skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #AAAAAA
    FontSize 13
    FontStyle bold
}
skinparam note {
    BackgroundColor #FFFFCC
    BorderColor #CCCCAA
}

' Espacement augmenté pour rendre les textes et cardinalités bien visibles
skinparam nodesep 80
skinparam ranksep 70
skinparam ArrowFontSize 13

title Diagramme de Classes — Consultation d'un Film

' ─────────────────────────────────────
'   ENTITÉS
' ─────────────────────────────────────

class Movie <<entity>> {
    - id : int
    - tmdbId : int
    - title : string
    - description : string
    - releaseDate : DateTimeInterface
    - poster : string
    - backdrop : string
    - director : string
    - rating : float
    - trailerKey : string
    - runtime : int
    __
    + getId() : ?int
    + getTmdbId() : ?int
    + getTitle() : ?string
    + getDescription() : ?string
    + getReleaseDate() : ?DateTimeInterface
    + getRating() : ?float
    + getRuntime() : ?int
    + getTrailerKey() : ?string
    + getGenres() : Collection
    + getPlatforms() : Collection
    + getMovieCastings() : Collection
}

class Genre <<entity>> {
    - id : int
    - genreName : string
    __
    + getId() : ?int
    + getGenreName() : ?string
    + setGenreName(name : string) : static
}

class Platform <<entity>> {
    - id : int
    - platformName : string
    __
    + getId() : ?int
    + getPlatformName() : ?string
    + setPlatformName(name : string) : static
}

class Casting <<entity>> {
    - id : int
    - name : string
    - profilePath : string
    __
    + getId() : ?int
    + getName() : ?string
    + getProfilePath() : ?string
}

class MovieCasting <<entity>> {
    - characterName : string
    - castOrder : int
    __
    + getMovie() : ?Movie
    + getCasting() : ?Casting
    + getCharacterName() : ?string
    + getCastOrder() : ?int
}

note bottom of MovieCasting
    Clé primaire composite
    (Id_Film, Id_Casting)
end note

' ─────────────────────────────────────
'   REPOSITORY
' ─────────────────────────────────────

class MovieRepository <<repository>> {
    + find(id : int) : ?Movie
    + findBy(criteria : array, orderBy : array, limit : int) : array
    + findOneByTmdbId(id : int) : ?Movie
}

' ─────────────────────────────────────
'   CONTRÔLEUR
' ─────────────────────────────────────

class MovieController <<controller>> {
    - entityManager : EntityManagerInterface
    __
    + list(repo : MovieRepository, request : Request) : JsonResponse
    + show(id : string, repo : MovieRepository) : JsonResponse
    - serializeMovie(movie : Movie, full : bool) : array
}

' ─────────────────────────────────────
'   SERVICES
' ─────────────────────────────────────

class TmdbService <<service>> {
    - client : HttpClientInterface
    - apiKey : string
    __
    + getGenres() : array
    + discoverStreamingMovies(page : int) : array
    + getMovieDetails(movieId : int) : array
    + getCredits(movieId : int) : array
    + getWatchProviders(movieId : int) : array
    + getVideos(movieId : int) : array
}

class OmdbService <<service>> {
    - client : HttpClientInterface
    - apiKey : string
    __
    + getRuntimeByTitle(title : string, year : string) : ?int
}

' ─────────────────────────────────────
'   FRONTEND
' ─────────────────────────────────────

class MovieContext <<provider>> {
    - movies : Movie[]
    - isLoading : boolean
    - error : string
    __
    + getMovie(id : string) : Movie
    + fetchMovieDetails(id : string) : Promise
    - getCachedMovies() : Movie[]
    - setCachedMovies(movies : Movie[]) : void
}

class MovieDetails <<page>> {
    - movie : Movie
    - isLocalLoading : boolean
    __
    Route : /movie/:id
}

class MoviesPage <<page>> {
    - searchQuery : string
    - selectedGenre : string
    - maxDuration : number
    - displayedCount : number
    __
    Route : /movies
}

class MovieCard <<component>> {
    + movie : Movie
    + onClick : Function
}

class MovieGrid <<component>> {
    + movies : Movie[]
}

class ApiService <<service>> {
    - baseURL : string
    __
    + get(url : string, config : object) : Promise
}

' ═════════════════════════════════════
'   RELATIONS ENTRE ENTITÉS (Doctrine)
' ═════════════════════════════════════

Movie "0..*" -up- "0..*" Genre
note on link : ManyToMany

Movie "0..*" -right- "0..*" Platform
note on link : ManyToMany

Movie "1" *-down- "0..*" MovieCasting
MovieCasting "0..*" -right-o "1" Casting

' ═════════════════════════════════════
'   DÉPENDANCES BACKEND
' ═════════════════════════════════════

MovieController .down.> MovieRepository : <<use>>
MovieController .down.> Movie : <<use>>
MovieRepository "1" -right- "0..*" Movie : gère >

TmdbService .up.> Movie : <<create>>
OmdbService .up.> Movie : <<create>>

' ═════════════════════════════════════
'   DÉPENDANCES FRONTEND
' ═════════════════════════════════════

MovieDetails .down.> MovieContext : <<use>>
MoviesPage .down.> MovieContext : <<use>>
MovieContext .down.> ApiService : <<use>>

MovieDetails "1" *-right- "0..*" MovieCard
MoviesPage "1" *-right- "1" MovieGrid
MovieGrid "1" *-down- "0..*" MovieCard

' ═════════════════════════════════════
'   FLUX API (Frontend → Backend)
' ═════════════════════════════════════

ApiService .down.> MovieController : GET /api/movies\nGET /api/movies/{id}

@enduml
